rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Authenticated users can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Other authenticated users can read basic profile (for app listings)
      allow read: if request.auth != null;
    }

    // Notifications: only the recipient can read/update their own
    match /notifications/{notifId} {
      allow read, update, delete: if request.auth != null &&
        resource.data.recipientId == request.auth.uid;
      // Cloud Functions write via Admin SDK (bypasses rules)
    }

    // notification_requests and reminder_requests: write-only for authenticated users
    // Cloud Functions process and delete these — no client reads needed
    match /notification_requests/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    match /reminder_requests/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Apps, participations, proofs, swaps — authenticated users
    match /{collection}/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
